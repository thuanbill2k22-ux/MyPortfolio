# Tạo file `.env` từ file mẫu này trước khi chạy app.
# Dùng EmailJS để nhận mail từ form Contact.

# ID service trong EmailJS
VITE_APP_SERVICE_ID=your_emailjs_service_id

# ID template trong EmailJS
VITE_APP_TEMPLATE_ID=your_emailjs_template_id

# Public key (EmailJS account -> Account -> Public Key)
VITE_APP_EMAILJS_KEY=your_emailjs_public_key

# Email nhận nội dung form contact của portfolio
# Lưu ý: code hiện tại đang đọc biến "RECIEVER" (đúng theo tên cũ của project)
VITE_APP_EMAILJS_RECIEVER=your_email@example.com